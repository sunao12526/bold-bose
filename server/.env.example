# Database connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable"

# JWT secret key for signing auth tokens (Replace with a strong random key in production)
JWT_SECRET="generate-a-strong-random-key-here"

# Application Base URL for notify callbacks
API_BASE_URL="http://localhost:3000/admin-api"

# JWT Token expiration settings
JWT_EXPIRES_IN="1d"
JWT_EXPIRES_IN_SECONDS=86400
JWT_REFRESH_EXPIRES_IN="7d"

