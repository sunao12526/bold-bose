  nextNotifyTime  DateTime?       @map("next_notify_time")
  responseContent String?         @map("response_content") @db.VarChar(2000)

  payOrder        PayOrder?       @relation(fields: [payOrderId], references: [id], onDelete: Cascade)
  refund          PayRefund?      @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@map("pay_notify_logs")
}

model Dept {
