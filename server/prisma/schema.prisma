datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MenuType {
  DIR
  MENU
  BUTTON
}

enum CommonStatus {
  ENABLE
  DISABLE
}

enum FileStorageType {
  LOCAL
  S3
}

model User {
  id        Int          @id @default(autoincrement())
  username  String       @unique @db.VarChar(50)
  password  String       @db.VarChar(100)
  nickname  String       @db.VarChar(50)
  email     String?      @db.VarChar(50)
  mobile    String?      @db.VarChar(20)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  roles     UserRole[]

  @@map("system_users")
}

model Role {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(50)
  code      String       @unique @db.VarChar(50)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users     UserRole[]
  menus     RoleMenu[]

  @@map("system_roles")
}

model Menu {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(50)
  permission String?      @db.VarChar(100)
  type       MenuType     @default(MENU)
  parentId   Int?         @map("parent_id")
  path       String?      @db.VarChar(200)
  icon       String?      @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  component  String?      @db.VarChar(200)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  parent     Menu?        @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children   Menu[]       @relation("MenuToMenu")
  roles      RoleMenu[]

  @@map("system_menus")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("system_user_roles")
}

model RoleMenu {
  roleId Int  @map("role_id")
  menuId Int  @map("menu_id")
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("system_role_menus")
}

model FileConfig {
  id        Int             @id @default(autoincrement())
  name      String          @db.VarChar(100)
  storage   FileStorageType @default(LOCAL)
  config    Json
  master    Boolean         @default(false)
  remark    String?         @db.VarChar(500)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  files     File[]

  @@map("infra_file_configs")
}

model File {
  id        Int      @id @default(autoincrement())
  configId  Int      @map("config_id")
  name      String   @db.VarChar(256)
  path      String   @db.VarChar(512)
  url       String   @db.VarChar(512)
  type      String?  @db.VarChar(100)
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  config    FileConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("infra_files")
}

model DictType {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  type      String       @unique @db.VarChar(100)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  data      DictData[]

  @@map("system_dict_types")
}

model DictData {
  id         Int          @id @default(autoincrement())
  dictType   String       @map("dict_type") @db.VarChar(100)
  label      String       @db.VarChar(100)
  value      String       @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  colorType  String?      @map("color_type") @db.VarChar(50)
  remark     String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  type       DictType     @relation(fields: [dictType], references: [type], onDelete: Cascade)

  @@map("system_dict_data")
}

model SysConfig {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(500)
  visible   Boolean  @default(true)
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  username    String?  @db.VarChar(50)
  module      String   @db.VarChar(50)
  type        String   @db.VarChar(50)
  description String   @db.VarChar(500)
  path        String   @db.VarChar(200)
  method      String   @db.VarChar(10)
  ip          String   @db.VarChar(50)
  status      Int
  duration    Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_operation_logs")
}

model CodegenTable {
  id           Int             @id @default(autoincrement())
  tableName    String          @unique @map("table_name") @db.VarChar(100)
  tableComment String          @map("table_comment") @db.VarChar(500)
  className    String          @map("class_name") @db.VarChar(100)
  moduleName   String          @map("module_name") @db.VarChar(100)
  businessName String          @map("business_name") @db.VarChar(100)
  classComment String          @map("class_comment") @db.VarChar(200)
  author       String          @db.VarChar(50)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  columns      CodegenColumn[]

  @@map("infra_codegen_tables")
}

model CodegenColumn {
  id                     Int          @id @default(autoincrement())
  tableId                Int          @map("table_id")
  columnName             String       @map("column_name") @db.VarChar(100)
  dataType               String       @map("data_type") @db.VarChar(100)
  columnComment          String       @map("column_comment") @db.VarChar(500)
  nullable               Boolean      @default(true)
  primaryKey             Boolean      @default(false) @map("primary_key")
  autoIncrement          Boolean      @default(false) @map("auto_increment")
  tsType                 String       @map("ts_type") @db.VarChar(50)
  prismaType             String       @map("prisma_type") @db.VarChar(50)
  crud                   Boolean      @default(true)
  listOperation          Boolean      @default(true) @map("list_operation")
  listOperationCondition String       @default("=") @map("list_operation_condition") @db.VarChar(20)
  formOperation          Boolean      @default(true) @map("form_operation")
  htmlType               String       @default("input") @map("html_type") @db.VarChar(50)
  dictType               String?      @map("dict_type") @db.VarChar(100)

  table                  CodegenTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("infra_codegen_columns")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(100)
  content   String?  @db.Text
  status    String?  @default("ENABLE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_posts")
}

model SysJob {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(100)
  handlerName    String       @map("handler_name") @db.VarChar(100) // e.g. logCleanupJob
  cronExpression String       @map("cron_expression") @db.VarChar(100) // e.g. 0 0 2 * * *
  status         CommonStatus @default(ENABLE)
  remark         String?      @db.VarChar(500)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  logs           SysJobLog[]

  @@map("infra_jobs")
}

model SysJobLog {
  id           Int      @id @default(autoincrement())
  jobId        Int      @map("job_id")
  handlerName  String   @map("handler_name") @db.VarChar(100)
  status       Int      // 200 = Success, 500 = Error
  duration     Int      // Run duration in ms
  errorMessage String?  @map("error_message") @db.VarChar(2000)
  createdAt    DateTime @default(now()) @map("created_at")

  job          SysJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("infra_job_logs")
}

model NotifyTemplate {
  id           Int             @id @default(autoincrement())
  name         String          @db.VarChar(100)
  code         String          @unique @db.VarChar(100) // e.g. user_welcome, code_captcha
  type         String          @db.VarChar(50) // SYSTEM (站内信), EMAIL, SMS
  title        String          @db.VarChar(200) // Subject or title
  content      String          @db.VarChar(2000) // e.g. Hello {nickname}, welcome!
  status       CommonStatus    @default(ENABLE)
  remark       String?         @db.VarChar(500)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  messages     NotifyMessage[]

  @@map("system_notify_templates")
}

model NotifyMessage {
  id           Int            @id @default(autoincrement())
  templateId   Int            @map("template_id")
  templateCode String         @map("template_code") @db.VarChar(100)
  userId       Int            @map("user_id")
  username     String         @db.VarChar(50)
  title        String         @db.VarChar(200)
  content      String         @db.VarChar(2000)
  read         Boolean        @default(false)
  readTime     DateTime?      @map("read_time")
  status       Int            // 200 = Success, 500 = Fail
  errorMessage String?        @map("error_message") @db.VarChar(1000)
  createdAt    DateTime       @default(now()) @map("created_at")

  template     NotifyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("system_notify_messages")
}

model UserSession {
  id             String   @id @default(uuid())
  token          String   @unique @db.VarChar(500)
  userId         Int      @map("user_id")
  username       String   @db.VarChar(50)
  nickname       String   @db.VarChar(50)
  ip             String   @db.VarChar(50)
  userAgent      String?  @map("user_agent") @db.VarChar(500)
  browser        String?  @db.VarChar(50)
  os             String?  @db.VarChar(50)
  loginTime      DateTime @default(now()) @map("login_time")
  lastActiveTime DateTime @default(now()) @map("last_active_time")
  expiresAt      DateTime @map("expires_at")

  @@map("system_user_sessions")
}

model MallCategory {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  parentId  Int?         @map("parent_id")
  picUrl    String?      @map("pic_url") @db.VarChar(512)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  parent    MallCategory?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Cascade)
  children  MallCategory[] @relation("CategoryToCategory")
  spus      MallSpu[]

  @@map("mall_categories")
}

model MallBrand {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  logo      String?      @db.VarChar(512)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  spus      MallSpu[]

  @@map("mall_brands")
}

model MallProperty {
  id        Int                 @id @default(autoincrement())
  name      String              @db.VarChar(100)
  remark    String?             @db.VarChar(500)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  values    MallPropertyValue[]

  @@map("mall_properties")
}

model MallPropertyValue {
  id         Int          @id @default(autoincrement())
  propertyId Int          @map("property_id")
  value      String       @db.VarChar(100)
  remark     String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  property   MallProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("mall_property_values")
}

model MallSpu {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(200)
  categoryId    Int          @map("category_id")
  brandId       Int?         @map("brand_id")
  picUrl        String       @map("pic_url") @db.VarChar(512)
  sliderPicUrls Json         @map("slider_pic_urls")
  description   String?      @db.Text
  sort          Int          @default(0)
  status        CommonStatus @default(ENABLE)
  salesCount    Int          @default(0) @map("sales_count")
  minPrice      Int          @default(0) @map("min_price")
  maxPrice      Int          @default(0) @map("max_price")
  totalStock    Int          @default(0) @map("total_stock")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  category      MallCategory @relation(fields: [categoryId], references: [id])
  brand         MallBrand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  skus          MallSku[]

  @@map("mall_spus")
}

model MallSku {
  id           Int      @id @default(autoincrement())
  spuId        Int      @map("spu_id")
  properties   Json
  price        Int
  marketPrice  Int?     @map("market_price")
  costPrice    Int?     @map("cost_price")
  stock        Int      @default(0)
  picUrl       String?  @map("pic_url") @db.VarChar(512)
  barCode      String?  @map("bar_code") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  spu          MallSpu  @relation(fields: [spuId], references: [id], onDelete: Cascade)

  @@map("mall_skus")
}
