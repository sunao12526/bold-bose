  payTime           DateTime?       @map("pay_time")
  expireTime        DateTime        @map("expire_at")
  merchantNotifyUrl String          @map("merchant_notify_url") @db.VarChar(512)
  notifyStatus      PayNotifyStatus @default(NO)

  app               PayApp          @relation(fields: [appId], references: [id], onDelete: Cascade)
  refunds           PayRefund[]
  notifyLogs        PayNotifyLog[]

