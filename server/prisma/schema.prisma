datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum MenuType {
  DIR
  MENU
  BUTTON
}

enum CommonStatus {
  ENABLE
  DISABLE
}

enum FileStorageType {
  LOCAL
  S3
}

model User {
  id        Int          @id @default(autoincrement())
  username  String       @unique @db.VarChar(50)
  password  String       @db.VarChar(100)
  nickname  String       @db.VarChar(50)
  avatar    String?      @db.VarChar(512)
  email     String?      @db.VarChar(50)
  mobile    String?      @db.VarChar(20)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  deptId    Int?         @map("dept_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  roles       UserRole[]
  dept        Dept?        @relation("UserDept", fields: [deptId], references: [id], onDelete: SetNull)
  deptLeader  Dept[]       @relation("DeptLeader")
  socialUsers SocialUser[]
  posts       UserPost[]

  @@map("system_users")
}

model Role {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(50)
  code      String       @unique @db.VarChar(50)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users     UserRole[]
  menus     RoleMenu[]

  @@map("system_roles")
}

model Menu {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(50)
  permission String?      @db.VarChar(100)
  type       MenuType     @default(MENU)
  parentId   Int?         @map("parent_id")
  path       String?      @db.VarChar(200)
  icon       String?      @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  component  String?      @db.VarChar(200)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  parent     Menu?        @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children   Menu[]       @relation("MenuToMenu")
  roles      RoleMenu[]

  @@map("system_menus")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("system_user_roles")
}

model RoleMenu {
  roleId Int  @map("role_id")
  menuId Int  @map("menu_id")
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("system_role_menus")
}

model FileConfig {
  id        Int             @id @default(autoincrement())
  name      String          @db.VarChar(100)
  storage   FileStorageType @default(LOCAL)
  config    Json
  master    Boolean         @default(false)
  remark    String?         @db.VarChar(500)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  files     File[]

  @@map("infra_file_configs")
}

model File {
  id        Int      @id @default(autoincrement())
  configId  Int      @map("config_id")
  name      String   @db.VarChar(256)
  path      String   @db.VarChar(512)
  url       String   @db.VarChar(512)
  type      String?  @db.VarChar(100)
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  config    FileConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("infra_files")
}

model DictType {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  type      String       @unique @db.VarChar(100)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  data      DictData[]

  @@map("system_dict_types")
}

model DictData {
  id         Int          @id @default(autoincrement())
  dictType   String       @map("dict_type") @db.VarChar(100)
  label      String       @db.VarChar(100)
  value      String       @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  colorType  String?      @map("color_type") @db.VarChar(50)
  remark     String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  type       DictType     @relation(fields: [dictType], references: [type], onDelete: Cascade)

  @@map("system_dict_data")
}

model SysConfig {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(500)
  visible   Boolean  @default(true)
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  username    String?  @db.VarChar(50)
  module      String   @db.VarChar(50)
  type        String   @db.VarChar(50)
  description String   @db.VarChar(500)
  path        String   @db.VarChar(200)
  method      String   @db.VarChar(10)
  ip          String   @db.VarChar(50)
  status      Int
  duration    Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_operation_logs")
}

model CodegenTable {
  id           Int             @id @default(autoincrement())
  tableName    String          @unique @map("table_name") @db.VarChar(100)
  tableComment String          @map("table_comment") @db.VarChar(500)
  className    String          @map("class_name") @db.VarChar(100)
  moduleName   String          @map("module_name") @db.VarChar(100)
  businessName String          @map("business_name") @db.VarChar(100)
  classComment String          @map("class_comment") @db.VarChar(200)
  author       String          @db.VarChar(50)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  columns      CodegenColumn[]

  @@map("infra_codegen_tables")
}

model CodegenColumn {
  id                     Int          @id @default(autoincrement())
  tableId                Int          @map("table_id")
  columnName             String       @map("column_name") @db.VarChar(100)
  dataType               String       @map("data_type") @db.VarChar(100)
  columnComment          String       @map("column_comment") @db.VarChar(500)
  nullable               Boolean      @default(true)
  primaryKey             Boolean      @default(false) @map("primary_key")
  autoIncrement          Boolean      @default(false) @map("auto_increment")
  tsType                 String       @map("ts_type") @db.VarChar(50)
  prismaType             String       @map("prisma_type") @db.VarChar(50)
  crud                   Boolean      @default(true)
  listOperation          Boolean      @default(true) @map("list_operation")
  listOperationCondition String       @default("=") @map("list_operation_condition") @db.VarChar(20)
  formOperation          Boolean      @default(true) @map("form_operation")
  htmlType               String       @default("input") @map("html_type") @db.VarChar(50)
  dictType               String?      @map("dict_type") @db.VarChar(100)

  table                  CodegenTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("infra_codegen_columns")
}

model Post {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  code      String       @db.VarChar(100)
  sort      Int
  remark    String?      @db.VarChar(500)
  status    CommonStatus @default(ENABLE)
  createdAt DateTime     @default(now()) @map("created_at")
  users     UserPost[]

  @@map("system_posts")
}

model SysJob {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(100)
  handlerName    String       @map("handler_name") @db.VarChar(100) // e.g. logCleanupJob
  cronExpression String       @map("cron_expression") @db.VarChar(100) // e.g. 0 0 2 * * *
  status         CommonStatus @default(ENABLE)
  remark         String?      @db.VarChar(500)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  logs           SysJobLog[]

  @@map("infra_jobs")
}

model SysJobLog {
  id           Int      @id @default(autoincrement())
  jobId        Int      @map("job_id")
  handlerName  String   @map("handler_name") @db.VarChar(100)
  status       Int      // 200 = Success, 500 = Error
  duration     Int      // Run duration in ms
  errorMessage String?  @map("error_message") @db.VarChar(2000)
  createdAt    DateTime @default(now()) @map("created_at")

  job          SysJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("infra_job_logs")
}

model NotifyTemplate {
  id           Int             @id @default(autoincrement())
  name         String          @db.VarChar(100)
  code         String          @unique @db.VarChar(100) // e.g. user_welcome, code_captcha
  type         String          @db.VarChar(50) // SYSTEM (站内信), EMAIL, SMS
  title        String          @db.VarChar(200) // Subject or title
  content      String          @db.VarChar(2000) // e.g. Hello {nickname}, welcome!
  status       CommonStatus    @default(ENABLE)
  remark       String?         @db.VarChar(500)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  messages     NotifyMessage[]

  @@map("system_notify_templates")
}

model NotifyMessage {
  id           Int            @id @default(autoincrement())
  templateId   Int            @map("template_id")
  templateCode String         @map("template_code") @db.VarChar(100)
  userId       Int            @map("user_id")
  username     String         @db.VarChar(50)
  title        String         @db.VarChar(200)
  content      String         @db.VarChar(2000)
  read         Boolean        @default(false)
  readTime     DateTime?      @map("read_time")
  status       Int            // 200 = Success, 500 = Fail
  errorMessage String?        @map("error_message") @db.VarChar(1000)
  createdAt    DateTime       @default(now()) @map("created_at")

  template     NotifyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("system_notify_messages")
}

model UserSession {
  id             String   @id @default(uuid())
  token          String   @unique @db.VarChar(500)
  userId         Int      @map("user_id")
  username       String   @db.VarChar(50)
  nickname       String   @db.VarChar(50)
  ip             String   @db.VarChar(50)
  userAgent      String?  @map("user_agent") @db.VarChar(500)
  browser        String?  @db.VarChar(50)
  os             String?  @db.VarChar(50)
  loginTime      DateTime @default(now()) @map("login_time")
  lastActiveTime DateTime @default(now()) @map("last_active_time")
  expiresAt      DateTime @map("expires_at")

  @@map("system_user_sessions")
}

model MallCategory {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  parentId  Int?         @map("parent_id")
  picUrl    String?      @map("pic_url") @db.VarChar(512)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  parent    MallCategory?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Cascade)
  children  MallCategory[] @relation("CategoryToCategory")
  spus      MallSpu[]

  @@map("mall_categories")
}

model MallBrand {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  logo      String?      @db.VarChar(512)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  spus      MallSpu[]

  @@map("mall_brands")
}

model MallProperty {
  id        Int                 @id @default(autoincrement())
  name      String              @db.VarChar(100)
  remark    String?             @db.VarChar(500)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  values    MallPropertyValue[]

  @@map("mall_properties")
}

model MallPropertyValue {
  id         Int          @id @default(autoincrement())
  propertyId Int          @map("property_id")
  value      String       @db.VarChar(100)
  remark     String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  property   MallProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("mall_property_values")
}

model MallSpu {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(200)
  categoryId    Int          @map("category_id")
  brandId       Int?         @map("brand_id")
  picUrl        String       @map("pic_url") @db.VarChar(512)
  sliderPicUrls Json         @map("slider_pic_urls")
  description   String?      @db.Text
  sort          Int          @default(0)
  status        CommonStatus @default(ENABLE)
  salesCount    Int          @default(0) @map("sales_count")
  minPrice      Int          @default(0) @map("min_price")
  maxPrice      Int          @default(0) @map("max_price")
  totalStock    Int          @default(0) @map("total_stock")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  category      MallCategory @relation(fields: [categoryId], references: [id])
  brand         MallBrand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  skus          MallSku[]

  @@map("mall_spus")
}

model MallSku {
  id           Int      @id @default(autoincrement())
  spuId        Int      @map("spu_id")
  properties   Json
  price        Int
  marketPrice  Int?     @map("market_price")
  costPrice    Int?     @map("cost_price")
  stock        Int      @default(0)
  picUrl       String?  @map("pic_url") @db.VarChar(512)
  barCode      String?  @map("bar_code") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  spu          MallSpu  @relation(fields: [spuId], references: [id], onDelete: Cascade)

  @@map("mall_skus")
}

enum MallOrderStatus {
  UNPAID
  UNDELIVERED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum MallRefundStatus {
  NONE
  APPLY
  APPROVED
  REJECTED
}

model MemberUser {
  id             Int                  @id @default(autoincrement())
  nickname       String               @db.VarChar(50)
  avatar         String?              @db.VarChar(512)
  mobile         String               @unique @db.VarChar(20)
  status         CommonStatus         @default(ENABLE)
  points         Int                  @default(0) // Member points
  balance        Int                  @default(0) // Balance in cents
  levelId        Int?                 @map("level_id")
  groupId        Int?                 @map("group_id")
  experience     Int                  @default(0) // Total experience points
  tagIds         Json?                @map("tag_ids") // JSON array of tag IDs
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  orders         MallOrder[]
  coupons        MallCouponUser[]
  signInRecords  MemberSignInRecord[]
  pointRecords   MemberPointRecord[]
  balanceRecords MemberBalanceRecord[]
  addresses      MemberAddress[]
  experienceRecords MemberExperienceRecord[]
  levelRecords MemberLevelRecord[]

  level          MemberLevel?         @relation(fields: [levelId], references: [id], onDelete: SetNull)
  group          MemberGroup?         @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("member_users")
}

model MemberLevel {
  id              Int          @id @default(autoincrement())
  name            String       @db.VarChar(50)
  level           Int          @unique // Level index, e.g. 1, 2, 3
  experience      Int          // Upgrade experience threshold
  discountPercent Int          @default(100) @map("discount_percent") // 90 means 90% (10% off)
  status          CommonStatus @default(ENABLE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  users           MemberUser[]

  @@map("member_levels")
}

model MemberTag {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(50)
  status      CommonStatus @default(ENABLE)
  description String?      @db.VarChar(200)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("member_tags")
}

model MemberSignInConfig {
  id        Int          @id @default(autoincrement())
  day       Int          @unique // Consecutive day index (e.g. 1-7)
  point     Int          // Reward points
  status    CommonStatus @default(ENABLE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("member_sign_in_configs")
}

model MemberSignInRecord {
  id        Int        @id @default(autoincrement())
  memberId  Int        @map("member_id")
  day       Int        // Consecutive day count of check-in
  point     Int        // Reward points
  createdAt DateTime   @default(now()) @map("created_at")

  member    MemberUser @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("member_sign_in_records")
}

model MallOrder {
  id              Int               @id @default(autoincrement())
  no              String            @unique @db.VarChar(100) // Order number
  memberId        Int               @map("member_id")
  status          MallOrderStatus   @default(UNPAID)
  payPrice        Int               @map("pay_price") // Payable price in cents
  totalPrice      Int               @map("total_price") // Original price in cents
  discountPrice   Int               @default(0) @map("discount_price") // Price discount in cents
  deliveryStatus  Boolean           @default(false) @map("delivery_status") // Shipped or not
  logisticsCo     String?           @map("logistics_co") @db.VarChar(100) // Logistics Company
  logisticsNo     String?           @map("logistics_no") @db.VarChar(100) // Tracking Number
  receiverName    String            @map("receiver_name") @db.VarChar(50)
  receiverMobile  String            @map("receiver_mobile") @db.VarChar(20)
  receiverAddress String            @map("receiver_address") @db.VarChar(512)
  userRemark      String?           @map("user_remark") @db.VarChar(500)
  payTime         DateTime?         @map("pay_time")
  deliveryTime    DateTime?         @map("delivery_time")
  receiveTime     DateTime?         @map("receive_time")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  member          MemberUser        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  items           MallOrderItem[]
  refunds         MallOrderRefund[]

  @@map("mall_orders")
}

model MallOrderItem {
  id         Int       @id @default(autoincrement())
  orderId    Int       @map("order_id")
  spuId      Int       @map("spu_id")
  skuId      Int       @map("sku_id")
  spuName    String    @map("spu_name") @db.VarChar(200)
  picUrl     String    @map("pic_url") @db.VarChar(512)
  properties Json      // SKU specs: [{propertyId, propertyName, valueId, valueName}]
  price      Int       // Selling price in cents
  count      Int       // Purchased quantity

  order      MallOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("mall_order_items")
}

model MallOrderRefund {
  id          Int              @id @default(autoincrement())
  no          String           @unique @db.VarChar(100) // Refund number
  orderId     Int              @map("order_id")
  memberId    Int              @map("member_id")
  refundPrice Int              @map("refund_price") // Refund amount in cents
  status      MallRefundStatus @default(APPLY)
  reason      String           @db.VarChar(200)
  userRemark  String?          @map("user_remark") @db.VarChar(500)
  auditRemark String?          @map("audit_remark") @db.VarChar(500)
  auditTime   DateTime?        @map("audit_time")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  order       MallOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("mall_order_refunds")
}

enum MallCouponType {
  CASH
  DISCOUNT
}

enum MallCouponScopeType {
  ALL
  CATEGORY
  SPU
}

enum MallCouponValidityType {
  DATE
  TERM
}

enum MallCouponUserStatus {
  UNUSED
  USED
  EXPIRED
}

model MallCoupon {
  id             Int                    @id @default(autoincrement())
  name           String                 @db.VarChar(100)
  type           MallCouponType         @default(CASH)
  minPrice       Int                    @default(0) @map("min_price") // Spend threshold in cents
  value          Int                    // Discount amount (cents for cash, percent for discount)
  totalCount     Int                    @default(0) @map("total_count") // Total stock
  takeCount      Int                    @default(0) @map("take_count") // Claimed amount
  useCount       Int                    @default(0) @map("use_count") // Used amount
  scopeType      MallCouponScopeType    @default(ALL) @map("scope_type")
  scopeValue     Json?                  @map("scope_value") // Array of Category or SPU IDs
  validityType   MallCouponValidityType @default(DATE) @map("validity_type")
  validStartTime DateTime?              @map("valid_start_time")
  validEndTime   DateTime?              @map("valid_end_time")
  validDays      Int?                   @map("valid_days")
  status         CommonStatus           @default(ENABLE)
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  userCoupons    MallCouponUser[]

  @@map("mall_coupons")
}

model MallCouponUser {
  id             Int                  @id @default(autoincrement())
  couponId       Int                  @map("coupon_id")
  memberId       Int                  @map("member_id")
  status         MallCouponUserStatus @default(UNUSED)
  useOrderId     Int?                 @map("use_order_id")
  validStartTime DateTime             @map("valid_start_time")
  validEndTime   DateTime             @map("valid_end_time")
  useTime        DateTime?            @map("use_time")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  coupon         MallCoupon           @relation(fields: [couponId], references: [id], onDelete: Cascade)
  member         MemberUser           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("mall_coupon_users")
}

enum PayOrderStatus {
  UNPAID
  SUCCESS
  CLOSED
}

enum PayRefundStatus {
  APPLY
  SUCCESS
  CLOSED
  FAIL
}

enum PayNotifyStatus {
  NO
  SUCCESS
  FAIL
}

enum PayNotifyType {
  ORDER
  REFUND
}

model PayApp {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(64)
  code      String       @unique @db.VarChar(64)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(512)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  channels  PayChannel[]
  orders    PayOrder[]

  @@map("pay_apps")
}

model PayChannel {
  id        Int          @id @default(autoincrement())
  appId     Int          @map("app_id")
  code      String       @db.VarChar(32) // e.g. "mock", "alipay", "wechat"
  config    Json
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(512)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  app       PayApp       @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, code])
  @@map("pay_channels")
