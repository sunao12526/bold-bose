datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MenuType {
  DIR
  MENU
  BUTTON
}

enum CommonStatus {
  ENABLE
  DISABLE
}

enum FileStorageType {
  LOCAL
  S3
}

model User {
  id        Int          @id @default(autoincrement())
  username  String       @unique @db.VarChar(50)
  password  String       @db.VarChar(100)
  nickname  String       @db.VarChar(50)
  email     String?      @db.VarChar(50)
  mobile    String?      @db.VarChar(20)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  roles     UserRole[]

  @@map("system_users")
}

model Role {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(50)
  code      String       @unique @db.VarChar(50)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users     UserRole[]
  menus     RoleMenu[]

  @@map("system_roles")
}

model Menu {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(50)
  permission String?      @db.VarChar(100)
  type       MenuType     @default(MENU)
  parentId   Int?         @map("parent_id")
  path       String?      @db.VarChar(200)
  icon       String?      @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  component  String?      @db.VarChar(200)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  parent     Menu?        @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children   Menu[]       @relation("MenuToMenu")
  roles      RoleMenu[]

  @@map("system_menus")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("system_user_roles")
}

model RoleMenu {
  roleId Int  @map("role_id")
  menuId Int  @map("menu_id")
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("system_role_menus")
}

model FileConfig {
  id        Int             @id @default(autoincrement())
  name      String          @db.VarChar(100)
  storage   FileStorageType @default(LOCAL)
  config    Json
  master    Boolean         @default(false)
  remark    String?         @db.VarChar(500)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  files     File[]

  @@map("infra_file_configs")
}

model File {
  id        Int      @id @default(autoincrement())
  configId  Int      @map("config_id")
  name      String   @db.VarChar(256)
  path      String   @db.VarChar(512)
  url       String   @db.VarChar(512)
  type      String?  @db.VarChar(100)
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  config    FileConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("infra_files")
}

model DictType {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  type      String       @unique @db.VarChar(100)
  status    CommonStatus @default(ENABLE)
  remark    String?      @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  data      DictData[]

  @@map("system_dict_types")
}

model DictData {
  id         Int          @id @default(autoincrement())
  dictType   String       @map("dict_type") @db.VarChar(100)
  label      String       @db.VarChar(100)
  value      String       @db.VarChar(100)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLE)
  colorType  String?      @map("color_type") @db.VarChar(50)
  remark     String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  type       DictType     @relation(fields: [dictType], references: [type], onDelete: Cascade)

  @@map("system_dict_data")
}

model SysConfig {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(500)
  visible   Boolean  @default(true)
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  username    String?  @db.VarChar(50)
  module      String   @db.VarChar(50)
  type        String   @db.VarChar(50)
  description String   @db.VarChar(500)
  path        String   @db.VarChar(200)
  method      String   @db.VarChar(10)
  ip          String   @db.VarChar(50)
  status      Int
  duration    Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_operation_logs")
}
